{
  "name": "vscode-mirror-ai",
  "displayName": "Mirror Ai",
  "description": "将 VSCode 与 Gemini 连接，实现 AI 辅助编程",
  "version": "1.1.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other", "Chat"],
  "icon": "media/icon128.png",
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mirrorAi.openPanel",
        "title": "打开 Mirror Ai 面板",
        "category": "Mirror Ai",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "mirrorAi.addCurrentFile",
        "title": "添加当前文件到 Mirror Ai",
        "category": "Mirror Ai",
        "icon": "$(file-add)"
      },
      {
        "command": "mirrorAi.addSelection",
        "title": "添加选中代码到 Mirror Ai",
        "category": "Mirror Ai",
        "icon": "$(selection)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "mirrorAi.openPanel",
          "group": "mirrorAi@1"
        },
        {
          "command": "mirrorAi.addCurrentFile",
          "group": "mirrorAi@2"
        },
        {
          "command": "mirrorAi.addSelection",
          "group": "mirrorAi@3",
          "when": "editorHasSelection"
        }
      ],
      "editor/title": [
        {
          "command": "mirrorAi.openPanel",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "mirrorAi.openPanel",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g"
      },
      {
        "command": "mirrorAi.addSelection",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a",
        "when": "editorHasSelection"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc --watch -p ./",
    "pretest": "npm run compile",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.10",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "ws": "^8.17.0"
  }
}
